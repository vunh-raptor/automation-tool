# Copy this file to .env and fill in the values before running the container.
#   cp .env.example .env
#
# .env is listed in .gitignore — never commit it to the repository.

# =============================================================================
# SECRETS — must be set, no default values
# =============================================================================

# MS Power Automate webhook triggered when an agent requests account reactivation.
# The URL contains an embedded HMAC signature; treat it as a password.
REACTIVATE_WEBHOOK_URL=

# MS Power Automate webhook triggered on automation errors to post to Teams.
ERROR_WEBHOOK_URL=

# Shared secret for the TOTP one-time password used to authorise reactivations.
# Generate a random base32 string, e.g.:
#   python -c "import base64, os; print(base64.b32encode(os.urandom(20)).decode())"
OTP_SECRET=

# =============================================================================
# INTERNAL SERVICE URLs — defaults match the production environment.
# Override only if your network topology differs (e.g. staging, test lab).
# =============================================================================

LDAP_URL=ldap://vn-ldaps.hcg.homecredit.net
LDAP_USER_OU=OU=Users,OU=VN,DC=hcg,DC=homecredit,DC=net
LDAP_USER_GROUP_DN=CN=VN.SD.SD_AUTOMATION_HUB.USER,OU=Groups,OU=VN,DC=hcg,DC=homecredit,DC=net

JIRA_URL=https://sd.homecredit.vn/rest/api/2/
SSO_URL=https://sso.homecredit.vn/opensso/identity/json/authenticate
AI_CHAT_API_URL=http://sd-auto.homecredit.vn:1234/ask
